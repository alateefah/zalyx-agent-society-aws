{
  "name": "zalyx-agent-society",
  "version": "0.1.0",
  "description": "Multi-agent underwriting system for merchant financing",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently \"ts-node-dev --respawn --transpile-only server.ts\" \"cd frontend && yarn dev\"",
    "server": "ts-node-dev --respawn --transpile-only server.ts",
    "build": "tsc && cd frontend && yarn build",
    "start": "node dist/server.js",
    "demo": "ts-node demo/sample-run.ts",
    "benchmark": "ts-node benchmark/run.ts",
    "test": "jest",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "agents",
    "aws",
    "bedrock",
    "dynamodb",
    "fintech",
    "underwriting",
    "halal-finance"
  ],
  "author": "Lateefah Adewale",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1072.0",
    "@aws-sdk/client-dynamodb": "^3.1072.0",
    "@aws-sdk/lib-dynamodb": "^3.1072.0",
    "@langchain/core": "^0.1.0",
    "@langchain/langgraph": "^0.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "openai": "^4.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.2",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.0"
  }
}
