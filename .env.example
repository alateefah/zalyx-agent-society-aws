# ── Amazon Bedrock (AI) ──────────────────────────────────────────────────────
# AWS credentials — use IAM role on ECS/EC2, or explicit keys locally
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Bedrock model — any model with tool use / function calling support
# Options: amazon.nova-pro-v1:0 | anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# Set to "true" to run without AWS credentials (realistic mock AI responses)
BEDROCK_MOCK_MODE=false

# ── Amazon DynamoDB ──────────────────────────────────────────────────────────
# Tables are created automatically on first run if they don't exist
DYNAMODB_MERCHANTS_TABLE=zalyx-merchants
DYNAMODB_DECISIONS_TABLE=zalyx-decisions

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
